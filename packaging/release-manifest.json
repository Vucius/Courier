{
  "name": "Courier",
  "binary": "courier-ui",
  "bundle_identifier": "dev.hephaestus.courier",
  "publisher": "Hephaestus",
  "license": "MIT",
  "database_schema": 3,
  "config_schema": 1,
  "artifacts": {
    "windows": {
      "binary": "courier-ui.exe",
      "installer": "Courier-Setup-${version}-x64.msi"
    },
    "linux": {
      "binary": "courier-ui",
      "appimage": "Courier-${version}-x86_64.AppImage",
      "deb": "courier_${version}_amd64.deb",
      "rpm": "courier-${version}-1.x86_64.rpm"
    },
    "macos": {
      "bundle": "Courier.app",
      "dmg": "Courier-${version}-macos.dmg"
    }
  },
  "installer_metadata": "packaging/installers/courier.installers.toml",
  "installer_builder": "packaging/build-installers.ps1",
  "icon_generator": "packaging/generate-icons.ps1",
  "data_preservation": {
    "user_data_dir": ".courier",
    "preserve_on_uninstall": true
  }
}
